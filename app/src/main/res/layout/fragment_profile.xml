<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/profileAvatar"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="Avatar"
            android:src="@drawable/ic_avatar_placeholder" />

        <TextView
            android:id="@+id/profileUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Benutzer"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/profileEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="email@example.com"
            android:visibility="gone"
            android:gravity="center" />

        <TextView
            android:id="@+id/profileRank"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rank"
            android:gravity="center"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/profileBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bio"
            android:visibility="gone"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/profileLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Ort"
            android:visibility="gone"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/profileBirthday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎂 Geburtstag"
            android:visibility="gone"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/profileDiscord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💬 Discord"
            android:visibility="gone"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/profileMinecraft"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚔ Minecraft"
            android:visibility="gone"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/profileHK"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍺 HK"
            android:visibility="gone"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center">

            <Button
                android:id="@+id/editProfileButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bearbeiten" />

            <Button
                android:id="@+id/syncButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Token generieren"
                android:layout_marginStart="8dp" />

            <Button
                android:id="@+id/logoutButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Abmelden"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/syncTokenCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="12dp"
            android:padding="12dp">

            <TextView
                android:id="@+id/syncTokenText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TOKEN" />
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnResetToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Token zurücksetzen"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
