<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/baf_black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/profileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profil"
            android:textColor="@color/baf_gold"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/profileUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Benutzername"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/profileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-Mail"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/profileRankApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="App-Rang:"
            android:textColor="@color/baf_gold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/profileRankIngame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingame-Rang:"
            android:textColor="@color/baf_gold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/profileUUID"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UUID:"
            android:textColor="@color/baf_gold"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/profileSyncButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Account synchronisieren"
            android:backgroundTint="@color/baf_gold"
            android:textColor="@android:color/black" />

    </LinearLayout>
</ScrollView>
