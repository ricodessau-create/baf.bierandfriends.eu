<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/baf_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/header_baf_samurai"
                android:scaleType="centerCrop"
                android:contentDescription="Header"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#99000000"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center"
                android:layout_marginBottom="16dp"
                android:text="PROFIL"
                android:textColor="@color/baf_gold"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">
                <ImageView
                    android:id="@+id/profileAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_profile_gaming"
                    android:background="@color/baf_card"
                    android:padding="8dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Profilbild"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:text="✎ Ändern"
                    android:textColor="@color/baf_gold"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:background="#CC000000"
                    android:padding="2dp"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/profileUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lade..."
                    android:textColor="@color/baf_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/profileEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/baf_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/profileRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/baf_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:background="@color/baf_card"/>

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/baf_gold_dark"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/profileBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/baf_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/profileLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/baf_text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="2dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/profileBirthday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/baf_text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="2dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/profileDiscord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/baf_text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="2dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/profileMinecraft"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/baf_text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="2dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/profileHK"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/baf_gold"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <Button
                android:id="@+id/editProfileButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="✏️  PROFIL BEARBEITEN"
                android:textColor="@color/baf_black"
                android:layout_marginBottom="8dp"
                style="@style/BAF.Button"/>

            <Button
                android:id="@+id/syncButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="⚔  MINECRAFT ACCOUNT VERKNÜPFEN"
                android:textColor="@color/baf_black"
                android:layout_marginBottom="8dp"
                style="@style/BAF.Button"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/syncTokenCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                style="@style/BAF.Card">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:text="Dein Sync-Token"
                        android:textColor="@color/baf_text_secondary"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/syncTokenText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/baf_gold"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginTop="8dp"/>
                    <TextView
                        android:text="Tippe /biersync TOKEN im Minecraft!"
                        android:textColor="@color/baf_text_secondary"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/baf_gold_dark"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/logoutButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="⏻  ABMELDEN"
                android:textColor="@color/baf_red"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
