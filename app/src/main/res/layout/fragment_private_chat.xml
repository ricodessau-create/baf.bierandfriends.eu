<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/baf_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/baf_black"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/privateChatBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/baf_gold"
            android:textSize="22sp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/privateChatTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/baf_gold"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/privateChatRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/baf_black"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/privateChatInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Nachricht..."
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@color/baf_card"
            android:padding="10dp"
            android:inputType="text"/>

        <Button
            android:id="@+id/privateChatSend"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="➤"
            android:textColor="@color/baf_black"
            android:layout_marginStart="8dp"
            style="@style/BAF.Button"/>

    </LinearLayout>

</LinearLayout>
