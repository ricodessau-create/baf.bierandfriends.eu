<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/baf_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/header_baf_samurai"
                android:scaleType="centerCrop"
                android:contentDescription="BAF Header"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#99000000"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center"
                android:layout_marginBottom="16dp"
                android:text="COMMUNITY"
                android:textColor="@color/baf_gold"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.15"/>
        </FrameLayout>

        <!-- Tabs -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="@color/baf_black">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tabFeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Feed"
                    android:textColor="@color/baf_gold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="14dp"/>
                <TextView
                    android:id="@+id/tabGruppen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gruppen"
                    android:textColor="@color/baf_tab_unselected"
                    android:textSize="14sp"
                    android:padding="14dp"/>
                <TextView
                    android:id="@+id/tabMitglieder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mitglieder"
                    android:textColor="@color/baf_tab_unselected"
                    android:textSize="14sp"
                    android:padding="14dp"/>
                <TextView
                    android:id="@+id/tabChat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chat"
                    android:textColor="@color/baf_tab_unselected"
                    android:textSize="14sp"
                    android:padding="14dp"/>
            </LinearLayout>
        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/baf_gold_dark"/>

        <TextView
            android:id="@+id/emptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Noch keine Beiträge."
            android:textColor="@color/baf_text_secondary"
            android:textSize="16sp"
            android:layout_margin="16dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/forumRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/newPostButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="80dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Neuer Beitrag"
        style="@style/BAF.FAB"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
