<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/baf_black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="BAF Logo"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:text="BierAndFriends"
            android:textColor="@color/baf_gold"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/loginEmail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="E-Mail"
            android:padding="12dp"
            android:background="#222222"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/loginPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Passwort"
            android:padding="12dp"
            android:background="#222222"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:inputType="textPassword"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Einloggen"
            android:backgroundTint="@color/baf_gold"
            android:textColor="@android:color/black" />

        <Button
            android:id="@+id/googleLoginButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Mit Google anmelden"
            android:backgroundTint="#FFFFFF"
            android:textColor="@android:color/black"
            android:layout_marginTop="8dp" />

        <ProgressBar
            android:id="@+id/loginProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/registerButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Noch kein Account? Registrieren"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@color/baf_gold"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</ScrollView>
