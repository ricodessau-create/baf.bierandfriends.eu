<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/baf_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:text="NEUES TICKET"
            android:textColor="@color/baf_gold"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Beschreibe dein Problem, wir helfen dir so schnell wie möglich."
            android:textColor="@color/baf_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Titel *"
            android:textColor="@color/baf_gold"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/ticketTitleInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Kurze Beschreibung des Problems"
            android:textColor="@color/baf_text_primary"
            android:textColorHint="@color/baf_text_secondary"
            android:background="@color/baf_card"
            android:padding="12dp"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:text="Beschreibung *"
            android:textColor="@color/baf_gold"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/ticketDescriptionInput"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:hint="Beschreibe das Problem so genau wie möglich..."
            android:textColor="@color/baf_text_primary"
            android:textColorHint="@color/baf_text_secondary"
            android:background="@color/baf_card"
            android:padding="12dp"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/submitTicketButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🎫 TICKET ABSENDEN"
            android:textColor="@color/baf_black"
            style="@style/BAF.Button"/>

    </LinearLayout>

</ScrollView>
