<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/baf_background">

    <!-- Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="140dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/header_baf_samurai"
            android:scaleType="centerCrop"
            android:contentDescription="Header"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#99000000"/>
        <TextView
            android:id="@+id/ticketDetailBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="12dp"
            android:text="← Zurück"
            android:textColor="@color/baf_gold"
            android:textSize="15sp"
            android:clickable="true"
            android:focusable="true"/>
    </FrameLayout>

    <!-- Ticket Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/ticketDetailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/baf_gold"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/ticketDetailStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@color/baf_card"
                android:textColor="@color/baf_gold"/>

            <TextView
                android:id="@+id/ticketDetailDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/baf_text_secondary"
                android:textSize="12sp"
                android:gravity="end"
                android:layout_gravity="center_vertical"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/baf_gold_dark"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/ticketDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/baf_text_primary"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/ticketDetailAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/baf_text_secondary"
            android:textSize="12sp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/baf_gold_dark"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💬 Nachrichten"
        android:textColor="@color/baf_gold"
        android:textSize="14sp"
        android:textStyle="bold"
        android:padding="16dp"/>

    <!-- Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ticketMessagesRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Message Input -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/baf_gold_dark"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/baf_card"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/ticketMessageInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Nachricht schreiben..."
            android:textColor="@color/baf_text_primary"
            android:textColorHint="@color/baf_text_secondary"
            android:background="@color/baf_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="text"
            android:maxLines="1"/>

        <Button
            android:id="@+id/ticketSendButton"
            android:layout_width="50dp"
            android:layout_height="44dp"
            android:text="➤"
            android:textColor="@color/baf_black"
            android:textSize="16sp"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/baf_gold"/>

    </LinearLayout>

</LinearLayout>
