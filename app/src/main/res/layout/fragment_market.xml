<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/baf_black">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <EditText
            android:id="@+id/marketSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Suche..."
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="#222222"
            android:layout_marginBottom="12dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/filterContainer"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/filterOwn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Eigene"
                    android:backgroundTint="#333333"
                    android:textColor="#FFD700"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/filterWithImage"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Mit Bild"
                    android:backgroundTint="#333333"
                    android:textColor="#FFD700"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/sortPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Preis ↑"
                    android:backgroundTint="#333333"
                    android:textColor="#FFD700"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/sortNewest"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Neueste"
                    android:backgroundTint="#333333"
                    android:textColor="#FFD700"
                    android:layout_marginEnd="8dp" />

            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/marketRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="96dp"
            android:clipToPadding="false"
            android:padding="8dp"/>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addItemButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Neues Angebot"
        style="@style/BAF.FAB"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
