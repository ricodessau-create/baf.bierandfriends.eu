<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/baf_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/header_baf_samurai"
                android:scaleType="centerCrop"
                android:contentDescription="Header"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#99000000"/>
            <TextView
                android:id="@+id/backButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="12dp"
                android:text="← Zurück"
                android:textColor="@color/baf_gold"
                android:textSize="15sp"
                android:clickable="true"
                android:focusable="true"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/userAvatar"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_profile_gaming"
                android:background="@color/baf_card"
                android:padding="8dp"
                android:scaleType="centerCrop"
                android:contentDescription="Avatar"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/userUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/baf_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/userEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/baf_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/userRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/baf_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:background="@color/baf_card"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/userBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/baf_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/userLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/baf_text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/userMinecraft"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/baf_text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/baf_gold_dark"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/messageButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="💬 NACHRICHT SENDEN"
                android:textColor="@color/baf_black"
                android:layout_marginBottom="8dp"
                style="@style/BAF.Button"/>

            <Button
                android:id="@+id/ignoreButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🔇 Ignorieren"
                android:textColor="@color/baf_red"
                android:layout_marginBottom="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
