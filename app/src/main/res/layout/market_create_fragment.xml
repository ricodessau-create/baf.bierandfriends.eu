<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/baf_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:text="ANGEBOT ERSTELLEN"
            android:textColor="@color/baf_gold"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Verkauf/Kauf Auswahl -->
        <TextView
            android:text="Typ *"
            android:textColor="@color/baf_gold"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/typeVerkauf"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="📦 Verkauf"
                android:backgroundTint="@color/baf_gold"
                android:textColor="@color/baf_black"
                android:textSize="13sp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/typeKauf"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="🛒 Kaufgesuch"
                android:backgroundTint="@color/baf_card"
                android:textColor="@color/baf_gold"
                android:textSize="13sp"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <!-- Kategorie -->
        <TextView
            android:text="Kategorie *"
            android:textColor="@color/baf_gold"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/catBloecke"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🧱 Blöcke"
                    android:backgroundTint="@color/baf_card"
                    android:textColor="@color/baf_gold"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/catRuestung"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🛡️ Rüstung"
                    android:backgroundTint="@color/baf_card"
                    android:textColor="@color/baf_gold"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/catWerkzeuge"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="⛏️ Werkzeuge"
                    android:backgroundTint="@color/baf_card"
                    android:textColor="@color/baf_gold"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/catGrundstuecke"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🏠 Grundstücke"
                    android:backgroundTint="@color/baf_card"
                    android:textColor="@color/baf_gold"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/catSonstiges"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:backgroundTint="@color/baf_gold"
                    android:text="📦 Sonstiges"
                    android:textColor="@color/baf_black"
                    android:textSize="12sp"/>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Bild -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="10dp"
            android:background="@color/baf_card">

            <TextView
                android:id="@+id/createImagePlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="📷 Bild auswählen (optional)"
                android:textColor="@color/baf_text_secondary"
                android:gravity="center"
                android:textSize="15sp"/>

            <ImageView
                android:id="@+id/createImagePreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Vorschau"/>

        </FrameLayout>

        <Button
            android:id="@+id/createSelectImageButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="📷 BILD AUSWÄHLEN"
            android:textColor="@color/baf_black"
            android:layout_marginBottom="12dp"
            style="@style/BAF.Button"/>

        <TextView
            android:text="Titel *"
            android:textColor="@color/baf_gold"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/createTitle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="z.B. Diamantschwert Schärfe V"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="@color/baf_card"
            android:padding="12dp"
            android:inputType="text"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:text="Beschreibung *"
            android:textColor="@color/baf_gold"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/createDescription"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Beschreibe dein Angebot..."
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="@color/baf_card"
            android:padding="12dp"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:text="Preis in HK *"
            android:textColor="@color/baf_gold"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/createPrice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="z.B. 1000"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="@color/baf_card"
            android:padding="12dp"
            android:inputType="numberDecimal"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/createSaveButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="ANGEBOT ERSTELLEN"
            android:textColor="@color/baf_black"
            style="@style/BAF.Button"/>

    </LinearLayout>

</ScrollView>
