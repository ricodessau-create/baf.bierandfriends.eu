<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="BAF" parent="Widget.MaterialComponents.CardView"/>

    <style name="BAF.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/baf_card</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/baf_gold</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="BAF.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/baf_gold</item>
        <item name="android:textColor">@color/baf_black</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">4dp</item>
    </style>

    <style name="BAF.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/baf_gold</item>
        <item name="tint">@color/baf_black</item>
    </style>

    <style name="BAF.TabText">
        <item name="android:textColor">@color/baf_text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <style name="BAF.OptionButton">
        <item name="android:background">@color/baf_card</item>
        <item name="android:textColor">@color/baf_gold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">14dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">start|center_vertical</item>
    </style>

</resources>
