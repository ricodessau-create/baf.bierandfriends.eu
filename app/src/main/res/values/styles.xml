<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="BAF.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/baf_dark_gray</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/baf_gold_dark</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="BAF.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/baf_gold</item>
        <item name="android:textColor">@color/baf_black</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="BAF.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/baf_gold</item>
        <item name="tint">@color/baf_black</item>
    </style>

</resources>
