<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.BAF" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/baf_gold</item>
        <item name="colorPrimaryVariant">@color/baf_gold_dark</item>
        <item name="colorOnPrimary">@color/baf_black</item>
        <item name="colorSecondary">@color/baf_gold</item>
        <item name="colorOnSecondary">@color/baf_black</item>
        <item name="android:windowBackground">@color/baf_background</item>
        <item name="android:statusBarColor">@color/baf_black</item>
        <item name="android:navigationBarColor">@color/baf_black</item>
        <item name="bottomNavigationStyle">@style/BAF.BottomNav</item>
    </style>

    <style name="BAF.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/baf_black</item>
        <item name="itemIconTint">@color/nav_item_colors</item>
        <item name="itemTextColor">@color/nav_item_colors</item>
    </style>

</resources>
